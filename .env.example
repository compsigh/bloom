# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# URL for OAuth redirects on localhost
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (OAuth 2.0 Client IDs in Google Cloud Console)
# Authorized redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Notion (create an internal integration at https://www.notion.so/my-integrations)
# Share both databases with the integration via "Connections" on each DB
NOTION_INTEGRATION_SECRET=
NOTION_REGISTRANTS_DATABASE_ID=
NOTION_MEMBER_LIST_DATABASE_ID=
